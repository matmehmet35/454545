{
  "manifest_version": 3,
  "name": "Stake Limbo Bot Pro",
  "version": "1.1",
  "description": "Limbo - Belli kayipta hedef artir",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [{
    "matches": ["https://stake.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}